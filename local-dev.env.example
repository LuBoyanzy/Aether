# Beszel 本地开发环境变量示例
# 复制为 `local-dev.env` 后按本机环境修改。

# Hub: PostgreSQL formal ingest monitor
AETHER_HUB_INGEST_MONITOR_PG_HOST=localhost
AETHER_HUB_INGEST_MONITOR_PG_PORT=5432
AETHER_HUB_INGEST_MONITOR_PG_USER=app_user
AETHER_HUB_INGEST_MONITOR_PG_PASSWORD=app_pass
AETHER_HUB_INGEST_MONITOR_PG_DATABASE=i3d_multitenant
AETHER_HUB_INGEST_MONITOR_PG_TENANT=guochuang
AETHER_HUB_INGEST_MONITOR_PG_SSLMODE=disable

# Hub: generic local dev
AETHER_HUB_DATA_CLEANUP_KEY=0123456789abcdef0123456789abcdef
AETHER_HUB_LICENSE_PRIVATE_KEY_FILE=/data/zhuangruiyan/beszel/.hq-license/license_signing_ed25519_private.pem
AETHER_HUB_LICENSE_MODEL_MANIFEST=/data/zhuangruiyan/beszel/.hq-license/model_security_manifest.json
APP_URL=http://192.168.140.2:19090

# Agent local dev
AETHER_AGENT_LOG_LEVEL=debug
HUB_URL=http://192.168.140.2:19090

# 如果你希望把 Agent 的 KEY / TOKEN 也放到本地文件里，可自行取消注释并填写。
# KEY="ssh-ed25519 ..."
# TOKEN=...
